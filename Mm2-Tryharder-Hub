-- WALKSPEED
PlayerTab:AddToggle({
    Name = "Ativar Velocidade",
    Default = false,
    Callback = function(Value)
        env.WalkEnabled = Value

        -- Para o loop antigo se existir
        if env.WalkLoop then
            env.WalkLoop = false
            task.wait(0.1)
        end

        if Value then
            -- Aplica a velocidade atual
            if Char and Hum and env.WalkSpeed then
                Hum.WalkSpeed = env.WalkSpeed
            end
            -- Inicia o loop de manutenção
            env.WalkLoop = true
            task.spawn(function()
                while env.WalkLoop and env.WalkEnabled do
                    if Char and Hum and env.WalkSpeed then
                        if Hum.WalkSpeed ~= env.WalkSpeed then
                            Hum.WalkSpeed = env.WalkSpeed
                        end
                    end
                    task.wait(0.1) -- verifica a cada 0.1s
                end
            end)
        else
            -- Desliga e volta ao normal
            env.WalkLoop = false
            if Char and Hum then
                Hum.WalkSpeed = 16
            end
        end
    end
})


PlayerTab:AddSlider({
    Name = "JumpPower",
    Min = 50,
    Max = 500,
    Default = 50,
    Color = Color3.fromRGB(255,255,255),
    Increment = 1,
    ValueName = "Potência",
    Callback = function(Value)
        env.JumpPower = Value
        if env.JumpEnabled then
            updateChar()
            if Hum then Hum.JumpPower = Value end
        end
    end
})

-- INFINITY JUMP
PlayerTab:AddToggle({
    Name = "Infinity Jump",
    Default = false,
    Callback = function(Value)
        env.InfiniteJump = Value
        if env.JumpConnection then
            env.JumpConnection:Disconnect()
            env.JumpConnection = nil
        end
        if Value then
            env.JumpConnection = game:GetService("UserInputService").JumpRequest:Connect(function()
                if env.InfiniteJump then
                    updateChar()
                    if Hum then
                        Hum:ChangeState("Jumping")
                    end
                end
            end)
        end
    end
})

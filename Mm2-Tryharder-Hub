-- ========== DISPARAR (REMOTE - SEM MOUSE) ==========
MainTab:AddToggle({
    Name = "Disparar (Remote)",
    Default = false,
    Callback = function(Value)
        -- ===== FUNÇÃO QUE ATIRA PARA FRENTE =====
        local function shootForward()
            if not Char then
                OrionLib:MakeNotification({
                    Name = "Tryharder Hub",
                    Content = "Personagem não carregado!",
                    Image = "rbxassetid://7733658504",
                    Time = 2
                })
                return
            end

            -- Verifica se tem arma
            local gun = Char:FindFirstChild("Gun")
            if not gun then
                local backpackGun = LocalPlayer:FindFirstChild("Backpack"):FindFirstChild("Gun")
                if backpackGun then
                    backpackGun.Parent = Char
                    gun = Char:FindFirstChild("Gun")
                end
            end

            if not gun then
                OrionLib:MakeNotification({
                    Name = "Tryharder Hub",
                    Content = "Pegue uma arma primeiro!",
                    Image = "rbxassetid://7733658504",
                    Time = 2
                })
                return
            end

            -- Obtém o Handle
            local handle = gun:FindFirstChild("Handle")
            if not handle then
                OrionLib:MakeNotification({
                    Name = "Tryharder Hub",
                    Content = "Handle não encontrado!",
                    Image = "rbxassetid://7733658504",
                    Time = 2
                })
                return
            end

            -- Posição da arma e alvo (10 metros para frente)
            local originPos = handle.Position
            local targetPos = originPos + Vector3.new(0, 0, -10)

            -- ===== MÉTODO 1: CreateBeam (mobile-friendly) =====
            local fired = false
            pcall(function()
                local knifeLocal = gun:FindFirstChild("KnifeLocal")
                if knifeLocal then
                    local createBeam = knifeLocal:FindFirstChild("CreateBeam")
                    if createBeam then
                        local remote = createBeam:FindFirstChild("RemoteFunction")
                        if remote and remote:IsA("RemoteFunction") then
                            remote:InvokeServer(1, targetPos, "AH2")
                            fired = true
                            OrionLib:MakeNotification({
                                Name = "Tryharder Hub",
                                Content = "✅ Tiro (CreateBeam)!",
                                Image = "rbxassetid://7733658504",
                                Time = 2
                            })
                        end
                    end
                end
            end)

            if fired then return end

            -- ===== MÉTODO 2: GunFired (via ReplicatedStorage) =====
            pcall(function()
                local weaponService = ReplicatedStorage:FindFirstChild("ClientServices")
                if weaponService then
                    weaponService = weaponService:FindFirstChild("WeaponService")
                    if weaponService then
                        local gunFired = weaponService:FindFirstChild("GunFired")
                        if gunFired and gunFired:IsA("RemoteEvent") then
                            gunFired:FireServer(handle, originPos, targetPos, handle)
                            fired = true
                            OrionLib:MakeNotification({
                                Name = "Tryharder Hub",
                                Content = "✅ Tiro (GunFired)!",
                                Image = "rbxassetid://7733658504",
                                Time = 2
                            })
                        end
                    end
                end
            end)

            if not fired then
                OrionLib:MakeNotification({
                    Name = "Tryharder Hub",
                    Content = "❌ Nenhum remote encontrado!",
                    Image = "rbxassetid://7733658504",
                    Time = 3
                })
            end
        end

        -- ===== CRIA O BOTÃO NA TELA =====
        local guip = gethui and gethui() or game:FindFirstChild("CoreGui") or LocalPlayer:FindFirstChild("PlayerGui")
        local function createButton()
            if not guip then return end
            if guip:FindFirstChild("ShootRemoteBtn") then guip:FindFirstChild("ShootRemoteBtn"):Destroy() end

            local screenGui = Instance.new("ScreenGui")
            screenGui.Name = "ShootRemoteBtn"
            screenGui.Parent = guip

            local button = Instance.new("TextButton")
            button.Name = "ShootRemote"
            button.Parent = screenGui
            button.Size = UDim2.new(0, 120, 0, 55)
            button.Position = UDim2.new(0.5, -60, 0.8, 0)
            button.Text = "🔫 ATIRAR"
            button.TextColor3 = Color3.fromRGB(255, 255, 255)
            button.TextSize = 16
            button.Font = Enum.Font.GothamBold
            button.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
            button.BorderColor3 = Color3.fromRGB(255, 255, 255)
            button.BorderSizePixel = 2
            button.Draggable = true
            button.Visible = true

            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0, 8)
            corner.Parent = button

            button.MouseButton1Click:Connect(shootForward)
        end

        if Value then
            createButton()
        else
            if guip and guip:FindFirstChild("ShootRemoteBtn") then
                guip:FindFirstChild("ShootRemoteBtn"):Destroy()
            end
        end
    end
})

